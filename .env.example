# 复制为 .env 并填入真实值；.env 已在 .gitignore 中排除，不要提交，不要把真实Key粘贴进 Docs/*.md

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

GLM_API_KEY=your_glm_api_key_here
GLM_MODEL_NAME=glm-4.7-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

LLM_PROVIDER=deepseek
LLM_FALLBACK_PROVIDER=glm

# 雅思Task 1图片理解专用，复用GLM_API_KEY/GLM_BASE_URL，只是模型名不同——
# GLM_MODEL_NAME那个纯文本模型不认图片输入，实测glm-4.6v-flash当前限流严重
# （HTTP 429），glm-4v-flash实测可正常调用，先用这个。
GLM_VISION_MODEL_NAME=glm-4v-flash

# 本地PostgreSQL（用户历史/进步追踪，见src/storage/db.py），本地要先装好并
# 跑着PostgreSQL（本机是`scoop install postgresql`装的，默认trust本地认证，
# 超级用户postgres、空密码，见Docs/03-RUNNING.md「数据库」）。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=huibi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# 部署到服务器时才需要，纯本地运行用不到（见CLAUDE.md"服务器部署（备用）"）
DEPLOY_HOST=your_server_ip
DEPLOY_USER=your_deploy_user
DEPLOY_PORT=22
